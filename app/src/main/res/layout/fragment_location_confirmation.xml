<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="24dp"
        android:background="@drawable/circle_white"
        android:elevation="4dp"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/gray_900" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardCornerRadius="30dp"
        app:cardElevation="16dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.GoRide.BottomSheet"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <View
                android:id="@+id/handle"
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:background="@color/gray_200"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Select address"
                android:textColor="@color/gray_900"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/handle" />

            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="@color/gray_100"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            <ImageView
                android:id="@+id/ivIndicator"
                android:layout_width="16dp"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:src="@drawable/ic_route_indicator"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider" />

            <TextView
                android:id="@+id/tvPickupLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Current location"
                android:textColor="@color/gray_900"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/ivIndicator"
                app:layout_constraintTop_toTopOf="@id/ivIndicator" />

            <TextView
                android:id="@+id/tvPickupAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="2972 Westheimer Rd. Santa Ana, Illinois 85486"
                android:textColor="@color/gray_500"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/tvPickupLabel"
                app:layout_constraintTop_toBottomOf="@id/tvPickupLabel" />

            <TextView
                android:id="@+id/tvDestLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Office"
                android:textColor="@color/gray_900"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/ivIndicator"
                app:layout_constraintBottom_toBottomOf="@id/ivIndicator" />

            <TextView
                android:id="@+id/tvDestAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="1901 Thornridge Cir. Shiloh, Hawaii 81063"
                android:textColor="@color/gray_500"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@+id/tvDistance"
                app:layout_constraintStart_toStartOf="@id/tvDestLabel"
                app:layout_constraintTop_toBottomOf="@id/tvDestLabel" />

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.1km"
                android:textColor="@color/gray_900"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@id/tvDestAddress"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvDestLabel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/primary"
                android:text="Confirm Location"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:layout_constraintTop_toBottomOf="@id/ivIndicator" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>