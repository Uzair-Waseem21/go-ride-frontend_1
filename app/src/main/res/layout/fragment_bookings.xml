<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <TextView
        android:id="@+id/tvTitle"
        style="@style/TextAppearance.GoRide.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="My Bookings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Active Ride Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActiveRide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Ride"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/gray_100" />

                    <TextView
                        android:id="@+id/tvActiveDriver"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Driver: Loading..."
                        android:textColor="@color/gray_900"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvActiveStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@color/primary_light"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="ACCEPTED"
                        android:textColor="@color/primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvActivePickup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Pickup: Loading..."
                        android:textColor="@color/gray_700"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvActiveDest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Drop: Loading..."
                        android:textColor="@color/gray_700"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvHistoryHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Ride History"
                android:textColor="@color/gray_900"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRideHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:itemCount="3"
                tools:listitem="@layout/item_ride_history" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/layout_empty_state" />
    <include layout="@layout/layout_error" />
    <include layout="@layout/layout_loading" />

</androidx.constraintlayout.widget.ConstraintLayout>